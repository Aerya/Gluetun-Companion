        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "gluetun_companion_server_active{provider=~\"$provider\",profile=~\"$profile\",server=~\"$server\"} == 1",
          "legendFormat": "{{server}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
